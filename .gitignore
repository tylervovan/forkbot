# Secrets — defensive, repo should never contain these
.env
.env.*
!.env.example
*.pem
*.key
*.token
credentials.json
secrets.json
tailscale-authkey*

# Arduino build caches
*.hex
*.elf
build-*/

# Misc
*.bak
*.orig
*.rej

# Docs (kept local only)
docs/
